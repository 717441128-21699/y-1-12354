{
  "name": "high-value-consumables-management",
  "version": "1.0.0",
  "description": "高值耗材智能管理系统 - 入库、领用、消耗、报表全流程管理",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
