    "start": "node dist/app.js",
    "init:db": "ts-node src/database/init.ts",
    "test": "ts-node src/tests/run-tests.ts"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.10",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "node-cron": "^3.0.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.9",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.19",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^9.0.8",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
